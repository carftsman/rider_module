  IncentiveSlab          IncentiveSlab[]
  RiderIncentiveProgress RiderIncentiveProgress[]

  @@index([incentiveType])
  @@index([status])
}

model IncentivePayout {
  id                     String                  @id
  incentiveId            String
  riderId                String
  progressId             String?
  earnedAmount           Float
  payoutStatus           PayoutStatus            @default(PENDING)
  payoutReferenceId      String?
