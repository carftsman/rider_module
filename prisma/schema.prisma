generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rider {
  id                     String                   @id @default(uuid())
  countryCode            String                   @default("+91")
  phoneNumber            String                   @unique
  phoneIsVerified        Boolean                  @default(false)
  otpCode                String?
  otpExpiresAt           DateTime?
  lastOtpVerifiedAt      DateTime?
  refreshToken           String?
  deviceToken            String?
  fcmToken               String?
  onboardingStage        OnboardingStage          @default(PHONE_VERIFICATION)
  isFullyRegistered      Boolean                  @default(false)
  isOnline               Boolean                  @default(false)
  orderState             OrderState               @default(READY)
  currentOrderId         String?
  partnerId              String?                  @unique
  isPartnerActive        Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  companyName            String?
  dob                    DateTime?
  email                  String?
  empId                  String?                  @unique
  riderType              RiderType                @default(INDIVIDUAL_EMPLOYEE)
  isStackable            Boolean                  @default(false)
  referredByPartnerId    String?
  IncentivePayout        IncentivePayout[]
  Order                  Order[]
  orderRiderEarnings     OrderRiderEarning[]
  programEnrollments     ProgramEnrollment[]
  programPayouts         ProgramPayout[]
  programProgresses      ProgramProgress[]
  programTaskProgresses  ProgramTaskProgress[]
  referralReceived       Referral?                @relation("Referee")
  referralsGiven         Referral[]               @relation("Referrer")
  bankDetails            RiderBankDetails?
  cashInHand             RiderCashInHand?
  deliveryStatus         RiderDeliveryStatus?
  gps                    RiderGps?
  gpsHistory             RiderGpsHistory[]
  RiderIncentiveProgress RiderIncentiveProgress[]
  kitAddress             RiderKitAddress?
  kyc                    RiderKyc?
  location               RiderLocation?
  onboarding             RiderOnboarding?
  performance            RiderPerformance[]
  permissions            RiderPermissions?
  profile                RiderProfile?
  ratings                RiderRating[]
  selfie                 RiderSelfie?
  status                 RiderStatus?
  vehicle                RiderVehicle?
  wallet                 RiderWallet?
  walletTransactions     RiderWalletTransaction[]
  slotBookings           SlotBooking[]
  slotRiders             SlotRider[]
  rider_assets           rider_assets[]
  deliveryWebhookEvents  DeliveryWebhookEvent[]

  @@index([phoneNumber])
  @@index([isOnline])
  @@index([orderState])
}

model RiderOnboarding {
  id                       String  @id @default(uuid())
  riderId                  String  @unique
  phoneVerified            Boolean @default(false)
  appPermissionDone        Boolean @default(false)
  citySelected             Boolean @default(false)
  vehicleSelected          Boolean @default(false)
  personalInfoSubmitted    Boolean @default(false)
  selfieUploaded           Boolean @default(false)
  aadharVerified           Boolean @default(false)
  panUploaded              Boolean @default(false)
  dlUploaded               Boolean @default(false)
  kycCompleted             Boolean @default(false)
  documentDetailsSubmitted Boolean @default(false)
  employeeDetailsSubmitted Boolean @default(false)
  employeeKycVerified      Boolean @default(false)
  riderType                Boolean @default(false)
  rider                    Rider   @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderPermissions {
  id                 String  @id @default(uuid())
  riderId            String  @unique
  camera             Boolean @default(false)
  foregroundLocation Boolean @default(false)
  backgroundLocation Boolean @default(false)
  rider              Rider   @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderStatus {
  id                      String    @id @default(uuid())
  riderId                 String    @unique
  lastLoginAt             DateTime?
  lastLogoutAt            DateTime?
  totalOnlineMinutesToday Int       @default(0)
  onlineMinutesDate       DateTime?
  availabilityScore       Float     @default(0)
  isOnline                Boolean   @default(false)
  lastScoreUpdatedAt      DateTime?
  lastTripAt              DateTime?
  tripsToday              Int       @default(0)
  rider                   Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderGps {
  id        String    @id @default(uuid())
  riderId   String    @unique
  isEnabled Boolean
  latitude  Float?
  longitude Float?
  updatedAt DateTime?
  accuracy  Float?
  heading   Float?
  speed     Float?
  rider     Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

model RiderProfile {
  id             String    @id @default(uuid())
  riderId        String    @unique
  fullName       String?
  dob            DateTime?
  gender         Gender?
  primaryPhone   String?
  secondaryPhone String?
  email          String?
  rider          Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderVehicle {
  id      String      @id @default(uuid())
  riderId String      @unique
  type    VehicleType
  rider   Rider       @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderSelfie {
  id         String   @id @default(uuid())
  riderId    String   @unique
  url        String
  uploadedAt DateTime
  rider      Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderKyc {
  id                   String             @id @default(uuid())
  riderId              String             @unique
  aadharStatus         VerificationStatus @default(pending)
  aadharRejectedReason String?
  panNumber            String?
  panImage             String?
  panStatus            VerificationStatus @default(pending)
  panRejectedReason    String?
  panOcrAttempts       Int                @default(0)
  panAllowManual       Boolean            @default(false)
  dlNumber             String?
  dlFrontImage         String?
  dlBackImage          String?
  dlStatus             VerificationStatus @default(pending)
  dlRejectedReason     String?
  dlOcrAttempts        Int                @default(0)
  dlAllowManual        Boolean            @default(false)
  rider                Rider              @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderBankDetails {
  id                     String                 @id @default(uuid())
  riderId                String                 @unique
  bankName               String?
  accountHolderName      String?
  accountType            AccountType?
  branch                 String?
  accountNumber          String?
  ifscCode               String?
  ifscVerificationStatus IfscVerificationStatus @default(PENDING)
  bankVerificationStatus BankVerificationStatus @default(PENDING)
  verifiedAt             DateTime?
  rider                  Rider                  @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderWallet {
  id             String @id @default(uuid())
  riderId        String @unique
  balance        Float  @default(0)
  totalEarned    Float  @default(0)
  totalWithdrawn Float  @default(0)
  rider          Rider  @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderCashInHand {
  id            String    @id @default(uuid())
  riderId       String    @unique
  balance       Float     @default(0)
  limit         Float     @default(250000)
  lastUpdatedAt DateTime?
  rider         Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderKitAddress {
  id                  String  @id @default(uuid())
  riderId             String  @unique
  name                String?
  mobileNumber        String?
  completeAddress     String?
  landmark            String?
  pincode             String?
  onboardingKitStatus Boolean @default(false)
  rider               Rider   @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderDeliveryStatus {
  id             String         @id @default(uuid())
  riderId        String         @unique
  isActive       Boolean        @default(false)
  inactiveReason InactiveReason @default(MANUAL_OFF)
  updatedAt      DateTime?
  rider          Rider          @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model AssetMaster {
  id             String           @id @default(uuid())
  assetType      AssetType        @unique
  price          Float
  freeLimit      Int
  issuedCount    Int              @default(0)
  isActive       Boolean          @default(true)
  assetName      String?
  imageUrl       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  availableStock Int              @default(0)
  totalAddedQty  Int              @default(0)
  inventories    AssetInventory[]
}

model AssetRequest {
  id               String        @id @default(uuid())
  riderId          String
  assetType        AssetType
  quantity         Int
  status           RequestStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  deliveryMode     DeliveryMode?
  pickupLocationId String?
  Payment          Payment?
  Shipment         Shipment?
}

model EMIPlan {
  id              String   @id @default(uuid())
  paymentId       String   @unique
  totalAmount     Float
  interestRate    Float
  months          Int
  monthlyAmount   Float
  remainingAmount Float
  nextDueDate     DateTime
  createdAt       DateTime @default(now())
  Payment         Payment  @relation(fields: [paymentId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  assetRequestId String        @unique
  amount         Float
  paymentMode    PaymentMode
  paymentType    PaymentType
  status         PaymentStatus @default(PENDING)
  transactionId  String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  EMIPlan        EMIPlan?
  AssetRequest   AssetRequest  @relation(fields: [assetRequestId], references: [id])
}

model Shipment {
  id             String         @id @default(uuid())
  assetRequestId String         @unique
  courierName    String?
  trackingId     String?
  dispatchDate   DateTime?
  deliveredDate  DateTime?
  deliveryStatus DeliveryStatus @default(NOT_DISPATCHED)
  AssetRequest   AssetRequest   @relation(fields: [assetRequestId], references: [id])
}

model rider_asset_issues {
  id            String           @id @default(uuid())
  riderAssetsId String
  assetType     AssetType
  assetName     String?
  issueType     AssetIssueType   @default(OTHER)
  description   String?
  imageUrl      String?
  status        AssetIssueStatus @default(OPEN)
  raisedAt      DateTime         @default(now())
  resolvedAt    DateTime?
  requestId     String?
  rider_assets  rider_assets     @relation(fields: [riderAssetsId], references: [id], onDelete: Cascade)

  @@index([status])
}

model rider_asset_items {
  id            String         @id @default(uuid())
  riderAssetsId String
  assetType     AssetType
  assetName     String?
  quantity      Int            @default(1)
  issuedDate    DateTime       @default(now())
  returnedDate  DateTime?
  status        AssetStatus    @default(ISSUED)
  condition     AssetCondition @default(GOOD)
  rider_assets  rider_assets   @relation(fields: [riderAssetsId], references: [id], onDelete: Cascade)

  @@index([assetType])
}

model rider_assets {
  id                 String               @id @default(uuid())
  riderId            String
  issuedByAdminId    String?
  remarks            String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  rider_asset_issues rider_asset_issues[]
  rider_asset_items  rider_asset_items[]
  Rider              Rider                @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
}

model WeeklySlot {
  id           String        @id @default(uuid())
  weekNumber   Int
  year         Int
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cityId       String?
  pincodeId    String?
  slots        Slot[]
  slotBookings SlotBooking[]
  city         City?         @relation(fields: [cityId], references: [id])
  pincode      Pincode?      @relation(fields: [pincodeId], references: [id])

  @@unique([weekNumber, year, pincodeId])
  @@index([pincodeId])
}

model Slot {
  slotId          String           @id @default(uuid())
  weeklySlotId    String
  date            String
  slotKey         String
  dayOfWeek       DayOfWeek
  dayNumber       Int
  startTime       String
  endTime         String
  durationMinutes Int
  slotStartAt     DateTime
  slotEndAt       DateTime
  breakInMinutes  Int              @default(10)
  maxRiders       Int
  bookedRiders    Int              @default(0)
  isAvailable     Boolean          @default(true)
  isVisible       Boolean          @default(true)
  isLocked        Boolean          @default(false)
  autoLocked      Boolean          @default(false)
  isPeakSlot      Boolean          @default(false)
  incentiveText   String           @default("")
  incentiveAmount Float            @default(0)
  priority        Int              @default(0)
  status          WeeklySlotStatus @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  weeklySlot      WeeklySlot       @relation(fields: [weeklySlotId], references: [id], onDelete: Cascade)
  slotBookings    SlotBooking[]
  riderBookings   SlotRider[]

  @@index([slotKey])
  @@index([slotStartAt])
}

model SlotRider {
  id          String          @id @default(uuid())
  slotId      String
  riderId     String
  status      RiderSlotStatus
  bookedAt    DateTime        @default(now())
  cancelledAt DateTime?
  noShowAt    DateTime?
  rider       Rider           @relation(fields: [riderId], references: [id], onDelete: Cascade)
  slot        Slot            @relation(fields: [slotId], references: [slotId], onDelete: Cascade)

  @@unique([slotId, riderId])
}

model SlotBooking {
  id                 String            @id @default(uuid())
  riderId            String
  daySlotId          String
  slotId             String
  slotKey            String?
  date               String
  dayOfWeek          DayOfWeek
  dayNumber          Int
  weekNumber         Int
  year               Int
  startTime          String?
  endTime            String?
  slotStartAt        DateTime
  slotEndAt          DateTime
  totalMinutes       Int?
  isPeakSlot         Boolean           @default(false)
  incentiveText      String            @default("")
  status             SlotBookingStatus @default(BOOKED)
  progress           SlotProgress      @default(UPCOMING)
  bookedFrom         SlotBookedFrom    @default(APP)
  cancellationReason String            @default("")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  cityId             String?
  pincodeId          String?
  city               City?             @relation(fields: [cityId], references: [id])
  weeklySlot         WeeklySlot        @relation(fields: [daySlotId], references: [id])
  pincode            Pincode?          @relation(fields: [pincodeId], references: [id])
  rider              Rider             @relation(fields: [riderId], references: [id], onDelete: Cascade)
  slot               Slot              @relation(fields: [slotId], references: [slotId])

  @@unique([riderId, date, slotId])
  @@index([riderId])
  @@index([slotStartAt])
  @@index([status])
  @@index([pincodeId])
}

model Order {
  id                     String                 @id @default(uuid())
  orderId                String                 @unique
  riderId                String?
  vendorShopName         String
  orderStatus            OrderStatus            @default(CREATED)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  totalWeight            Float?
  riderRatingId          String?
  Rider                  Rider?                 @relation(fields: [riderId], references: [id])
  RiderRating            RiderRating?           @relation(fields: [riderRatingId], references: [id])
  OrderAllocation        OrderAllocation?
  OrderCancelIssue       OrderCancelIssue?
  chats                  OrderChat[]
  OrderCod               OrderCod?
  OrderDeliveryAddress   OrderDeliveryAddress?
  OrderItem              OrderItem[]
  OrderPayment           OrderPayment?
  OrderPickupAddress     OrderPickupAddress?
  OrderPricing           OrderPricing?
  OrderRiderEarning      OrderRiderEarning?
  OrderSettlement        OrderSettlement?
  OrderSlotInfo          OrderSlotInfo?
  OrderTracking          OrderTracking?
  storeId                String?
  deliveryId             String?                @unique
  deliveryConfirmationId String?                @unique
  deliveryWebhookEvents  DeliveryWebhookEvent[]

  @@index([orderStatus])
  @@index([riderId])
  @@index([createdAt])
}

model OrderPickupAddress {
  id            String  @id @default(uuid())
  orderId       String  @unique
  name          String?
  addressLine   String?
  contactNumber String?
  latitude      Float?
  longitude     Float?
  pincode       String?
  Order         Order   @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

model OrderDeliveryAddress {
  id            String  @id @default(uuid())
  orderId       String  @unique
  name          String?
  addressLine   String?
  contactNumber String?
  latitude      Float?
  longitude     Float?
  Order         Order   @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

model OrderRiderEarning {
  id           String       @id @default(uuid())
  orderId      String       @unique
  riderId      String?
  basePay      Float        @default(0)
  distancePay  Float        @default(0)
  surgePay     Float        @default(0)
  tips         Float        @default(0)
  totalEarning Float        @default(0)
  credited     Boolean      @default(false)
  creditedAt   DateTime?
  Order        Order        @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  Rider        Rider?       @relation(fields: [riderId], references: [id], onDelete: Cascade)
  OrderSurges  OrderSurge[]

  @@index([orderId])
  @@index([riderId])
}

model OrderSurge {
  id                String            @id @default(uuid())
  riderEarningId    String
  type              SurgeType
  multiplierType    MultiplierType
  value             Float?
  OrderRiderEarning OrderRiderEarning @relation(fields: [riderEarningId], references: [id], onDelete: Cascade)
}

model OrderSlotInfo {
  id            String    @id @default(uuid())
  orderId       String    @unique
  slotBookingId String?
  slotId        String?
  isSlotBooked  Boolean   @default(false)
  isPeakSlot    Boolean?
  slotStartAt   DateTime?
  slotEndAt     DateTime?
  Order         Order     @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

model OrderAllocation {
  id                   String                @id @default(uuid())
  orderId              String                @unique
  assignedAt           DateTime?
  expiresAt            DateTime?
  Order                Order                 @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  OrderCandidateRiders OrderCandidateRider[]

  @@index([orderId])
}

model OrderCancelIssue {
  id          String       @id @default(uuid())
  orderId     String       @unique
  cancelledBy CancelledBy?
  reasonCode  String?
  reasonText  String?
  Order       Order        @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

model OrderSettlement {
  id                String   @id @default(uuid())
  orderId           String   @unique
  riderEarningAdded Boolean  @default(false)
  vendorSettled     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  Order             Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

model AssetInventory {
  id            String      @id @default(uuid())
  assetMasterId String
  addedQuantity Int
  availableQty  Int
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  assetMaster   AssetMaster @relation(fields: [assetMasterId], references: [id], onDelete: Cascade)

  @@index([assetMasterId])
}

model City {
  id           String        @id @default(cuid())
  name         String        @unique
  state        String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pincodes     Pincode[]
  slotBookings SlotBooking[]
  weeklySlots  WeeklySlot[]
}

model Pincode {
  id             String          @id @default(cuid())
  code           String
  name           String
  isActive       Boolean         @default(true)
  cityId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  areas          Area[]
  city           City            @relation(fields: [cityId], references: [id])
  slotBookings   SlotBooking[]
  weeklySlots    WeeklySlot[]
  pincodeMetrics PincodeMetrics?

  @@unique([code, cityId])
}

model Area {
  id               String          @id @default(cuid())
  name             String
  isActive         Boolean         @default(true)
  pincodeId        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  pincode          Pincode         @relation(fields: [pincodeId], references: [id])
  metrics          PincodeMetrics? @relation(fields: [pincodeMetricsId], references: [id])
  pincodeMetricsId String?

  @@unique([name, pincodeId])
}

model RiderLocation {
  id            String  @id @default(uuid())
  riderId       String  @unique
  streetAddress String?
  area          String?
  city          String?
  state         String?
  pincode       String?
  rider         Rider   @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderPerformance {
  id                  String    @id @default(uuid())
  riderId             String
  periodStart         DateTime
  periodEnd           DateTime
  averageRating       Float     @default(0)
  totalRatings        Int       @default(0)
  totalOrdersAssigned Int       @default(0)
  totalOrdersAccepted Int       @default(0)
  totalOrdersRejected Int       @default(0)
  rejectionPenalty    Float     @default(0)
  performanceScore    Float     @default(0.7)
  calculatedAt        DateTime  @default(now())
  acceptanceRate      Float     @default(0)
  date                DateTime?
  rider               Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, periodStart, periodEnd])
  @@unique([riderId, date])
  @@index([riderId])
}

model RiderGpsHistory {
  id         String   @id @default(uuid())
  riderId    String
  latitude   Float
  longitude  Float
  recordedAt DateTime @default(now())
  rider      Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId, recordedAt])
}

model RiderRating {
  id        String   @id @default(uuid())
  orderId   String   @unique
  riderId   String
  rating    Float
  review    String?
  createdAt DateTime @default(now())
  orders    Order[]
  rider     Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([createdAt])
}

model Program {
  id                    String                @id @default(uuid())
  name                  String
  description           String?
  programType           ProgramType
  pincodeIds            String[]
  applicableWhen        ApplicableWhen        @default(ALL)
  trackingType          TrackingType
  ruleType              RuleType
  validFrom             DateTime
  validTill             DateTime
  daysOfWeek            DayOfWeek[]
  weekStartDay          DayOfWeek?
  minAcceptanceRate     Float?
  minCompletionRate     Float?
  maxPayoutPerDay       Float?
  maxPayoutPerWeek      Float?
  validityDays          Int?
  isActive              Boolean               @default(true)
  priority              Int                   @default(1)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  cityId                String[]
  joiningBonusType      JoiningBonusType?
  consistency           ProgramConsistency?
  programEnrollments    ProgramEnrollment[]
  payouts               ProgramPayout[]
  progresses            ProgramProgress[]
  rules                 ProgramRule[]
  slabs                 ProgramSlab[]
  slots                 ProgramSlot[]
  targets               ProgramTarget[]
  tasks                 ProgramTask[]
  programTaskProgresses ProgramTaskProgress[]
  referrals             Referral[]
  referralConfig        ReferralConfig?

  @@index([trackingType, cityId, isActive])
  @@index([programType])
  @@index([isActive])
}

model ProgramRule {
  id             String  @id @default(uuid())
  programId      String
  minOrders      Int?
  minEarnings    Float?
  perOrderAmount Float?
  program        Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model ProgramSlab {
  id           String         @id @default(uuid())
  programId    String
  role         IncentiveRole?
  minValue     Float
  maxValue     Float
  rewardAmount Float
  program      Program        @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model ProgramTarget {
  id             String  @id @default(uuid())
  programId      String
  targetOrders   Int?
  targetEarnings Float?
  rewardAmount   Float
  program        Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model ProgramTask {
  id                    String                @id @default(uuid())
  programId             String
  role                  IncentiveRole?
  dayNumber             Int?
  minOrders             Int?
  rewardAmount          Float                 @default(0)
  minAcceptanceRate     Float?
  minEarnings           Float?
  minPeakSlots          Int?
  taskType              TaskType              @default(ORDERS)
  fixedReward           Float?
  maxEarning            Float?
  maxOrders             Int?
  rewardPerOrder        Float?
  targetOrders          Int?
  taskRuleType          RuleType?
  minCompletionRate     Float?
  program               Program               @relation(fields: [programId], references: [id], onDelete: Cascade)
  programTaskProgresses ProgramTaskProgress[]

  @@index([programId])
}

model ProgramSlot {
  id                String            @id @default(uuid())
  programId         String
  startMinutes      Int
  endMinutes        Int
  daysOfWeek        DayOfWeek[]
  ruleType          RuleType
  rewardPerOrder    Float?
  maxEarningPerSlot Float?
  minOrdersRequired Int?
  priority          Int               @default(1)
  program           Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  slabs             ProgramSlotSlab[]

  @@index([programId])
}

model ProgramSlotSlab {
  id           String      @id @default(uuid())
  slotId       String
  minOrders    Int
  maxOrders    Int
  rewardAmount Float
  slot         ProgramSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([slotId])
}

model ProgramConsistency {
  id              String  @id @default(uuid())
  programId       String  @unique
  minActiveDays   Int
  minOrdersPerDay Int
  program         Program @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model ReferralConfig {
  id                  String             @id @default(uuid())
  programId           String             @unique
  rewardFlow          ReferralRewardFlow
  maxReferralsPerUser Int?
  maxEarningPerUser   Float?
  program             Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model Referral {
  id                  String                @id @default(uuid())
  referrerId          String
  refereeId           String                @unique
  programId           String
  referralCode        String
  targetOrders        Int
  earnedAmount        Float                 @default(0)
  maxReward           Float?
  status              ReferralStatus        @default(NOT_STARTED)
  progressPercentage  Float                 @default(0)
  totalOrders         Int                   @default(0)
  joiningBonusGiven   Boolean               @default(false)
  joiningBonusGivenAt DateTime?
  isCompleted         Boolean               @default(false)
  completedAt         DateTime?
  rewardGiven         Boolean               @default(false)
  rewardGivenAt       DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  program             Program               @relation(fields: [programId], references: [id], onDelete: Cascade)
  referee             Rider                 @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)
  referrer            Rider                 @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  taskProgresses      ProgramTaskProgress[] @relation("ReferralTaskProgress")

  @@unique([referrerId, refereeId])
  @@index([referrerId])
  @@index([refereeId])
  @@index([referralCode])
}

model ProgramProgress {
  id            String    @id @default(uuid())
  riderId       String
  programId     String
  date          DateTime?
  week          String?
  totalOrders   Int       @default(0)
  totalEarnings Float     @default(0)
  activeDays    Int       @default(0)
  achieved      Boolean   @default(false)
  rewardAmount  Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  slotId        String?
  program       Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  rider         Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, programId, week])
  @@unique([riderId, programId, slotId, date])
  @@index([riderId, programId])
  @@index([date])
  @@index([week])
}

model ProgramPayout {
  id                  String            @id @default(uuid())
  riderId             String
  programId           String
  referralId          String?
  amount              Float
  status              PayoutStatus      @default(PENDING)
  walletTransactionId String?
  referenceId         String?
  creditedAt          DateTime?
  createdAt           DateTime          @default(now())
  triggerType         PayoutTriggerType
  program             Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  rider               Rider             @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([status])
  @@index([referralId])
}

model RiderWalletTransaction {
  id          String                @id @default(uuid())
  riderId     String
  type        WalletTransactionType
  amount      Float
  description String?
  referenceId String?
  createdAt   DateTime              @default(now())
  rider       Rider                 @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, referenceId, type])
  @@index([riderId])
  @@index([type])
  @@index([referenceId])
}

model ProgramEnrollment {
  id         String           @id @default(uuid())
  riderId    String
  programId  String
  enrolledAt DateTime         @default(now())
  expiresAt  DateTime
  status     EnrollmentStatus @default(ACTIVE)
  program    Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  rider      Rider            @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, programId])
  @@index([riderId])
  @@index([programId])
}

model ProgramTaskProgress {
  id            String         @id @default(uuid())
  enrollmentId  String?
  riderId       String
  programId     String
  taskId        String
  week          String?
  date          DateTime
  referralId    String?
  dayNumber     Int
  isCompleted   Boolean        @default(false)
  completedAt   DateTime?
  role          IncentiveRole?
  progressValue Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  program       Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  rider         Rider          @relation(fields: [riderId], references: [id], onDelete: Cascade)
  task          ProgramTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  referral      Referral?      @relation("ReferralTaskProgress", fields: [referralId], references: [id])

  @@unique([riderId, taskId, programId, week])
}

model OrderChat {
  id         String   @id @default(cuid())
  orderId    String
  senderId   String
  senderRole String
  message    String
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [orderId])
}

model ProcessedOrder {
  id        String   @id @default(uuid())
  orderId   String   @unique
  createdAt DateTime @default(now())
}

model PayoutConfig {
  id             String       @id @default(uuid())
  name           String
  scenarioType   String
  cityId         String?
  pincodeIds     String[]
  vehicleType    VehicleType?
  basePay        Float
  perKmRate      Float
  surgeConfig    Json
  weatherConfig  Json?
  peakConfig     Json?
  version        Int
  isActive       Boolean      @default(true)
  applicableFrom DateTime?
  applicableTill DateTime?
  isDefault      Boolean      @default(false)
  notes          String?
  createdBy      String?
  meta           Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([cityId, isActive])
  @@index([scenarioType])
}

model Zone {
  id           String        @id
  name         String
  city         String
  state        String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  zonePincodes ZonePincode[]
  zonePoints   ZonePoint[]
}

model ZonePoint {
  id             String   @id @default(cuid())
  name           String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  pincode        String
  latitude       Float
  longitude      Float
  radiusInMeters Int      @default(3000)
  zoneId         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  zone           Zone     @relation(fields: [zoneId], references: [id])

  @@index([pincode])
  @@index([latitude, longitude])
}

model ZonePincode {
  id      String @id @default(cuid())
  pincode String
  zoneId  String
