  Incentive            Incentive               @relation(fields: [incentiveId], references: [id])
  Rider                Rider                   @relation(fields: [riderId], references: [id])

  @@unique([riderId, incentiveId, date])
  @@index([incentiveId])
  @@index([riderId, date])
  @@index([riderId, week])
}

