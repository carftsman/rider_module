generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")
}

enum RiderType {
  INDIVIDUAL_EMPLOYEE

  COMPANY_EMPLOYEE
}

model Rider {
  id String @id @default(uuid())

  countryCode String @default("+91")

  phoneNumber String @unique

  phoneIsVerified Boolean @default(false)

  otpCode String?

  riderType RiderType @default(INDIVIDUAL_EMPLOYEE)

  otpExpiresAt DateTime?

  lastOtpVerifiedAt DateTime?

  refreshToken String?

  deviceToken String?

  fcmToken String?

  onboardingStage OnboardingStage @default(PHONE_VERIFICATION)

  isFullyRegistered Boolean @default(false)

  isOnline Boolean @default(false)

  orderState OrderState @default(READY)

  currentOrderId String?

  partnerId String? @unique

  isPartnerActive Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  companyName String?

  dob DateTime?

  email String?

  empId String? @unique

  Order Order[]

  orderRiderEarnings OrderRiderEarning[]

  bankDetails RiderBankDetails?

  cashInHand RiderCashInHand?

  deliveryStatus RiderDeliveryStatus?

  gps RiderGps?

  kitAddress RiderKitAddress?

  kyc RiderKyc?

  location RiderLocation?

  onboarding RiderOnboarding?

  permissions RiderPermissions?

  profile RiderProfile?

  selfie RiderSelfie?

  status RiderStatus?

  vehicle RiderVehicle?

  wallet       RiderWallet?
  isStackable  Boolean            @default(false)
  performance  RiderPerformance[]
  slotBookings SlotBooking[]
  gpsHistory   RiderGpsHistory[]
  slotRiders   SlotRider[]
  ratings      RiderRating[]
  rider_assets rider_assets[]

  riderIncentiveProgresses RiderIncentiveProgress[]
  incentivePayouts         IncentivePayout[]

  @@index([phoneNumber])
  @@index([isOnline])
  @@index([orderState])
}

model RiderOnboarding {
  id String @id @default(uuid())

  riderId String @unique

  phoneVerified Boolean @default(false)

  riderType Boolean @default(false)

  appPermissionDone Boolean @default(false)

  citySelected Boolean @default(false)

  vehicleSelected Boolean @default(false)

  personalInfoSubmitted Boolean @default(false)

  selfieUploaded Boolean @default(false)

  aadharVerified Boolean @default(false)

  panUploaded Boolean @default(false)

  dlUploaded Boolean @default(false)

  employeeDetailsSubmitted Boolean @default(false)

  documentDetailsSubmitted Boolean @default(false)

  employeeKycVerified Boolean @default(false)

  kycCompleted Boolean @default(false)

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderPermissions {
  id String @id @default(uuid())

  riderId String @unique

  camera Boolean @default(false)

  foregroundLocation Boolean @default(false)

  backgroundLocation Boolean @default(false)

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderStatus {
  id String @id @default(uuid())

  riderId String @unique

  lastLoginAt DateTime?

  lastLogoutAt DateTime?

  totalOnlineMinutesToday Int       @default(0)
  onlineMinutesDate       DateTime?
  tripsToday              Int       @default(0)
  lastTripAt              DateTime?

  availabilityScore  Float     @default(0)
  lastScoreUpdatedAt DateTime?

  isOnline Boolean @default(false)
  rider    Rider   @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderGps {
  id String @id @default(uuid())

  riderId String @unique

  isEnabled Boolean

  latitude Float?

  longitude Float?
  speed     Float? // km/h
  heading   Float? // 0–360 direction
  accuracy  Float?
  updatedAt DateTime?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

model RiderProfile {
  id String @id @default(uuid())

  riderId String @unique

  fullName String?

  dob DateTime?

  gender Gender?

  primaryPhone String?

  secondaryPhone String?

  email String?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderVehicle {
  id String @id @default(uuid())

  riderId String @unique

  type VehicleType

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderSelfie {
  id String @id @default(uuid())

  riderId String @unique

  url String

  uploadedAt DateTime

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderKyc {
  id String @id @default(uuid())

  riderId String @unique

  aadharStatus VerificationStatus @default(pending)

  aadharRejectedReason String?

  panNumber String?

  panImage String?

  panStatus VerificationStatus @default(pending)

  panRejectedReason String?

  panOcrAttempts Int @default(0)

  panAllowManual Boolean @default(false)

  dlNumber String?

  dlFrontImage String?

  dlBackImage String?

  dlStatus VerificationStatus @default(pending)

  dlRejectedReason String?

  dlOcrAttempts Int @default(0)

  dlAllowManual Boolean @default(false)

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderBankDetails {
  id String @id @default(uuid())

  riderId String @unique

  bankName String?

  accountHolderName String?

  accountType AccountType?

  branch String?

  accountNumber String?

  ifscCode String?

  ifscVerificationStatus IfscVerificationStatus @default(PENDING)

  bankVerificationStatus BankVerificationStatus @default(PENDING)

  verifiedAt DateTime?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderWallet {
  id String @id @default(uuid())

  riderId String @unique

  balance Float @default(0)

  totalEarned Float @default(0)

  totalWithdrawn Float @default(0)

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderCashInHand {
  id String @id @default(uuid())

  riderId String @unique

  balance Float @default(0)

  limit Float @default(250000)

  lastUpdatedAt DateTime?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderKitAddress {
  id String @id @default(uuid())

  riderId String @unique

  name String?

  mobileNumber String?

  completeAddress String?

  landmark String?

  pincode String?

  onboardingKitStatus Boolean @default(false)

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderDeliveryStatus {
  id String @id @default(uuid())

  riderId String @unique

  isActive Boolean @default(false)

  inactiveReason InactiveReason @default(MANUAL_OFF)

  updatedAt DateTime?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model AssetMaster {
  id String @id @default(uuid())

  assetType AssetType @unique

  price Float

  freeLimit Int

  issuedCount Int @default(0)

  isActive Boolean @default(true)

  assetName String?

  imageUrl      String?
  totalAddedQty Int     @default(0)

  availableStock Int      @default(0)
  createdAt      DateTime @default(now())

  updatedAt   DateTime         @updatedAt
  inventories AssetInventory[]
}

model AssetRequest {
  id String @id @default(uuid())

  riderId String

  assetType AssetType

  quantity Int

  status RequestStatus @default(PENDING)

  createdAt        DateTime      @default(now())
  deliveryMode     DeliveryMode?
  pickupLocationId String?
  Payment          Payment?

  Shipment Shipment?
}

model EMIPlan {
  id String @id @default(uuid())

  paymentId String @unique

  totalAmount Float

  interestRate Float

  months Int

  monthlyAmount Float

  remainingAmount Float

  nextDueDate DateTime

  createdAt DateTime @default(now())

  Payment Payment @relation(fields: [paymentId], references: [id])
}

model Payment {
  id String @id @default(uuid())

  assetRequestId String @unique

  amount Float

  paymentMode PaymentMode

  paymentType PaymentType

  status PaymentStatus @default(PENDING)

  transactionId String?

  paidAt DateTime?

  createdAt DateTime @default(now())

  EMIPlan EMIPlan?

  AssetRequest AssetRequest @relation(fields: [assetRequestId], references: [id])
}

model Shipment {
  id String @id @default(uuid())

  assetRequestId String @unique

  courierName String?

  trackingId String?

  dispatchDate DateTime?

  deliveredDate DateTime?

  deliveryStatus DeliveryStatus @default(NOT_DISPATCHED)

  AssetRequest AssetRequest @relation(fields: [assetRequestId], references: [id])
}

model rider_asset_issues {
  id            String  @id @default(uuid())
  requestId     String?
  riderAssetsId String

  assetType AssetType

  assetName String?

  issueType AssetIssueType @default(OTHER)

  description String?

  imageUrl String?

  status AssetIssueStatus @default(OPEN)

  raisedAt DateTime @default(now())

  resolvedAt DateTime?

  rider_assets rider_assets @relation(fields: [riderAssetsId], references: [id], onDelete: Cascade)

  @@index([status])
}

model rider_asset_items {
  id String @id @default(uuid())

  riderAssetsId String

  assetType AssetType

  assetName String?

  quantity Int @default(1)

  issuedDate DateTime @default(now())

  returnedDate DateTime?

  status AssetStatus @default(ISSUED)

  condition AssetCondition @default(GOOD)

  rider_assets rider_assets @relation(fields: [riderAssetsId], references: [id], onDelete: Cascade)

  @@index([assetType])
}

model rider_assets {
  id String @id @default(uuid())

  riderId String

  issuedByAdminId String?

  remarks String?

  createdAt DateTime @default(now())

  updatedAt DateTime

  rider_asset_issues rider_asset_issues[]

  rider_asset_items rider_asset_items[]

  Rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
}

model WeeklySlot {
  id String @id @default(uuid())

  weekNumber Int
  year       Int

  cityId    String?
  pincodeId String?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slots        Slot[]
  slotBookings SlotBooking[]

  city    City?    @relation(fields: [cityId], references: [id])
  pincode Pincode? @relation(fields: [pincodeId], references: [id])

  @@unique([weekNumber, year, pincodeId])
  @@index([pincodeId])
}

model Slot {
  slotId String @id @default(uuid())

  weeklySlotId String

  date String

  slotKey String

  dayOfWeek DayOfWeek

  dayNumber Int

  startTime String

  endTime String

  durationMinutes Int

  slotStartAt DateTime

  slotEndAt DateTime

  breakInMinutes Int @default(10)

  maxRiders Int

  bookedRiders Int @default(0)

  isAvailable Boolean @default(true)

  isVisible Boolean @default(true)

  isLocked Boolean @default(false)

  autoLocked Boolean @default(false)

  isPeakSlot Boolean @default(false)

  incentiveText String @default("")

  incentiveAmount Float @default(0)

  priority Int @default(0)

  status WeeklySlotStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  weeklySlot WeeklySlot @relation(fields: [weeklySlotId], references: [id], onDelete: Cascade)

  slotBookings SlotBooking[]

  riderBookings SlotRider[]

  @@index([slotKey])
  @@index([slotStartAt])
}

model SlotRider {
  id String @id @default(uuid())

  slotId String

  riderId String

  status RiderSlotStatus

  bookedAt DateTime @default(now())

  cancelledAt DateTime?

  noShowAt DateTime?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  slot Slot @relation(fields: [slotId], references: [slotId], onDelete: Cascade)

  @@unique([slotId, riderId])
}

model SlotBooking {
  id String @id @default(uuid())

  riderId   String
  daySlotId String
  slotId    String

  cityId    String?
  pincodeId String?

  slotKey    String?
  date       String
  dayOfWeek  DayOfWeek
  dayNumber  Int
  weekNumber Int
  year       Int

  startTime String?
  endTime   String?

  slotStartAt DateTime
  slotEndAt   DateTime

  totalMinutes Int?

  isPeakSlot    Boolean @default(false)
  incentiveText String  @default("")

  status   SlotBookingStatus @default(BOOKED)
  progress SlotProgress      @default(UPCOMING)

  bookedFrom SlotBookedFrom @default(APP)

  cancellationReason String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeklySlot WeeklySlot @relation(fields: [daySlotId], references: [id])
  rider      Rider      @relation(fields: [riderId], references: [id], onDelete: Cascade)
  slot       Slot       @relation(fields: [slotId], references: [slotId])

  city    City?    @relation(fields: [cityId], references: [id])
  pincode Pincode? @relation(fields: [pincodeId], references: [id])

  @@unique([riderId, date, slotId])
  @@index([riderId])
  @@index([slotStartAt])
  @@index([status])
  @@index([pincodeId])
}

//////////////////// ORDER ////////////////////

model Order {
  id String @id @default(uuid())

  orderId String @unique

  riderId String?

  vendorShopName String

  orderStatus OrderStatus @default(CREATED)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  Rider Rider? @relation(fields: [riderId], references: [id])

  OrderItems OrderItem[]

  OrderPricing OrderPricing?

  OrderPayment OrderPayment?

  OrderCod OrderCod?

  OrderPickupAddress OrderPickupAddress?

  OrderDeliveryAddress OrderDeliveryAddress?

  OrderRiderEarning OrderRiderEarning?

  OrderSlotInfo OrderSlotInfo?

  OrderTracking OrderTracking?

  OrderAllocation OrderAllocation?

  OrderCancelIssue OrderCancelIssue?

  OrderSettlement OrderSettlement?
  totalWeight     Float?

  @@index([orderStatus])
  @@index([riderId])
  @@index([createdAt])
}

//////////////////// ITEMS ////////////////////

model OrderItem {
  id String @id @default(uuid())

  orderId String

  itemName String

  quantity Int

  price Float

  total         Float
  weightPerUnit Float?
  createdAt     DateTime @default(now())

  updatedAt DateTime @updatedAt

  Order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

//////////////////// PRICING ////////////////////

model OrderPricing {
  id String @id @default(uuid())

  orderId String @unique

  itemTotal Float?

  deliveryFee Float?

  tax Float?

  platformCommission Float?

  totalAmount Float?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

//////////////////// PAYMENT ////////////////////

model OrderPayment {
  id String @id @default(uuid())

  orderId String @unique

  mode OrderPaymentMode

  codPaymentType CodPaymentType @default(CASH)

  status OrderPaymentStatus @default(PENDING)

  transactionId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
  @@index([mode])
  @@index([status])
  @@index([createdAt])
}

//////////////////// COD ////////////////////

model OrderCod {
  id String @id @default(uuid())

  orderId String @unique

  amount Float @default(0)

  depositedAmount Float @default(0)

  pendingAmount Float @default(0)

  status CodStatus @default(PENDING)

  collectedAt DateTime?

  depositedAt DateTime?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([collectedAt])
  @@index([depositedAt])
}

//////////////////// ADDRESSES ////////////////////

model OrderPickupAddress {
  id String @id @default(uuid())

  orderId String @unique

  name String?

  addressLine String?

  contactNumber String?

  latitude Float?

  longitude Float?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

model OrderDeliveryAddress {
  id String @id @default(uuid())

  orderId String @unique

  name String?

  addressLine String?

  contactNumber String?

  latitude Float?

  longitude Float?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

//////////////////// RIDER EARNING ////////////////////

model OrderRiderEarning {
  id String @id @default(uuid())

  orderId String @unique

  riderId String?

  basePay Float @default(0)

  distancePay Float @default(0)

  surgePay Float @default(0)

  tips Float @default(0)

  totalEarning Float @default(0)

  credited Boolean @default(false)

  creditedAt DateTime? // NEW FIELD

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  Rider Rider? @relation(fields: [riderId], references: [id], onDelete: Cascade)

  OrderSurges OrderSurge[]

  @@index([orderId])
  @@index([riderId])
}

model OrderSurge {
  id String @id @default(uuid())

  riderEarningId String

  type SurgeType

  multiplierType MultiplierType

  value Float?

  OrderRiderEarning OrderRiderEarning @relation(fields: [riderEarningId], references: [id], onDelete: Cascade)
}

//////////////////// SLOT INFO ////////////////////

model OrderSlotInfo {
  id String @id @default(uuid())

  orderId String @unique

  slotBookingId String?

  slotId String?

  isSlotBooked Boolean @default(false)

  isPeakSlot Boolean?

  slotStartAt DateTime?

  slotEndAt DateTime?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

//////////////////// TRACKING ////////////////////

model OrderTracking {
  id String @id @default(uuid())

  orderId String @unique

  distanceInKm Float?

  durationInMin Float?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

//////////////////// ALLOCATION ////////////////////

model OrderAllocation {
  id String @id @default(uuid())

  orderId String @unique

  assignedAt DateTime?

  expiresAt DateTime?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  OrderCandidateRiders OrderCandidateRider[]

  @@index([orderId])
}

model OrderCandidateRider {
  id String @id @default(uuid())

  allocationId String

  riderId String

  status AllocationStatus @default(PENDING)

  notifiedAt         DateTime?
  // ---------- PROXIMITY INPUTS ----------
  etaToVendor        Float     @default(0) // minutes
  etaToCustomer      Float     @default(0) // minutes
  distanceToVendor   Float     @default(0) // km
  distanceToCustomer Float     @default(0) // km
  directionScore     Float     @default(0) // 0 → 0.1
  // ---------- FINAL SCORES ----------
  proximityScore     Float     @default(0)
  availabilityScore  Float     @default(0)
  performanceScore   Float     @default(0)
  orderFitScore      Float     @default(0)
  externalScore      Float     @default(0)
  totalScore         Float     @default(0)

  scoringVersion Int      @default(1)
  calculatedAt   DateTime @default(now())

  OrderAllocation OrderAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@index([allocationId])
  @@index([riderId])
  @@index([totalScore])
}

//////////////////// CANCEL ISSUE ////////////////////

model OrderCancelIssue {
  id String @id @default(uuid())

  orderId String @unique

  cancelledBy CancelledBy?

  reasonCode String?

  reasonText String?

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

//////////////////// SETTLEMENT ////////////////////

model OrderSettlement {
  id String @id @default(uuid())

  orderId String @unique

  riderEarningAdded Boolean @default(false)

  vendorSettled Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  Order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
}

enum OnboardingStage {
  WELCOME_PAGE

  PHONE_VERIFICATION

  EMPLOYEE_TYPE

  APP_PERMISSIONS

  EMPLOYEE_DETAILS

  DOCUMENT_DETAILS

  EMPLOYEEKYC_VERIFICATION

  SELECT_LOCATION

  SELECT_VEHICLE

  PERSONAL_INFO

  SELFIE

  AADHAAR

  PAN_UPLOAD

  DL_UPLOAD

  KYC_SUBMITTED

  KYC_APPROVAL_PENDING

  KYC_APPROVED

  COMPLETED

  COMPANY_DETAILS

  VEHICLE_DETAILS
}

enum Gender {
  male

  female

  other
}

enum VehicleType {
  ev

  bike

  scooty
}

enum VerificationStatus {
  pending

  approved

  rejected
}

enum BankVerificationStatus {
  PENDING

  VERIFIED

  FAILED
}

enum IfscVerificationStatus {
  PENDING

  VERIFIED

  FAILED
}

enum AccountType {
  CURRENT

  SAVINGS
}

enum OrderState {
  READY

  BUSY
}

enum InactiveReason {
  MANUAL_OFF

  KYC_PENDING

  ACCOUNT_SUSPENDED

  OUT_OF_SERVICE_AREA

  COD_LIMIT_EXCEEDED
}

enum AssetCondition {
  GOOD

  BAD
}

enum AssetIssueStatus {
  OPEN

  IN_PROGRESS

  RESOLVED
}

enum AssetIssueType {
  DAMAGED

  LOST

  WRONG_SIZE

  OTHER
}

enum AssetStatus {
  ISSUED

  RETURNED

  LOST
}

enum AssetType {
  T_SHIRT

  BAG

  HELMET

  JACKET

  ID_CARD

  OTHER
}

enum DeliveryStatus {
  NOT_DISPATCHED

  SHIPPED

  DELIVERED
}

enum PaymentMode {
  ONLINE

  OFFLINE
}

enum PaymentStatus {
  PENDING

  SUCCESS

  FAILED
}

enum PaymentType {
  FULL

  EMI
}

enum RequestStatus {
  PENDING

  APPROVED

  REJECTED

  PAYMENT_PENDING

  READY_FOR_DISPATCH

  DISPATCHED

  COMPLETED

  CANCELLED
}

enum DayOfWeek {
  MON

  TUE

  WED

  THU

  FRI

  SAT

  SUN
}

enum SlotBookingStatus {
  BOOKED

  CANCELLED_BY_RIDER

  CANCELLED_BY_SYSTEM

  COMPLETED

  NO_SHOW
}

enum SlotProgress {
  UPCOMING

  RUNNING

  COMPLETED

  MISSED
}

enum SlotBookedFrom {
  APP

  ADMIN
}

enum WeeklySlotStatus {
  ACTIVE

  INACTIVE
}

enum RiderSlotStatus {
  BOOKED

  CANCELLED

  NO_SHOW

  COMPLETED
}

//////////////////// ENUMS ////////////////////

enum CancelledBy {
  CUSTOMER

  RIDER

  VENDOR

  ADMIN
}

enum CodPaymentType {
  CASH

  UPI

  BANK_TRANSFER
}

enum AllocationStatus {
  PENDING

  ACCEPTED

  REJECTED

  TIMEOUT
}

enum CodStatus {
  PENDING

  PARTIAL_DEPOSITED

  DEPOSITED
}

enum MultiplierType {
  FIXED

  PER_ORDER
}

enum OrderPaymentMode {
  ONLINE

  COD
}

enum OrderPaymentStatus {
  PENDING

  SUCCESS

  FAILED

  REFUNDED
}

enum OrderStatus {
  CREATED

  CONFIRMED

  ASSIGNED

  PICKED_UP

  DELIVERED

  CANCELLED
}

enum SurgeType {
  PEAK

  RAIN

  ZONE

  NIGHT

  HIGH_DEMAND
}

/////////////////////////////////////////////////////

// Rider Incentive Progress

/////////////////////////////////////////////////////

model RiderIncentiveProgress {
  id String @id @default(uuid())

  riderId String

  incentiveId String

  incentiveType IncentiveProgressType

  // Time scope

  date String?

  week String?

  // Order tracking

  totalOrders Int @default(0)

  peakOrders Int @default(0)

  normalOrders         Int @default(0)
  completedPeakSlots   Int @default(0)
  completedNormalSlots Int @default(0)

  orderIds String[]

  // Slot tracking

  slotName String?

  slotStart String?

  slotEnd String?

  slotCompleted Boolean @default(false)

  // Weekly tracking

  eligibleDays Int @default(0)

  dailyOrderMap Json?

  // Result

  achievedSlabOrders Int @default(0)

  achievedReward Float @default(0)

  baseEarning Float @default(0)

  eligible Boolean @default(false)

  status IncentiveProgressStatus @default(IN_PROGRESS)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  rider Rider @relation(fields: [riderId], references: [id])

  incentive Incentive @relation(fields: [incentiveId], references: [id])

  payouts IncentivePayout[]

  @@unique([riderId, incentiveId, date])
  @@index([riderId, date])
  @@index([riderId, week])
  @@index([incentiveId])
}

/////////////////////////////////////////////////////

// Incentive Master

/////////////////////////////////////////////////////

model Incentive {
  id String @id @default(uuid())

  title String

  description String?

  incentiveType IncentiveType

  validFrom DateTime?

  validTill DateTime?

  applicableCities String[]

  applicableZones String[]

  // Rider Filters

  minRating Float?

  vehicleType String?

  minCompletedOrders Int?

  // Slot config

  peakSlotEnabled Boolean @default(false)

  normalSlotEnabled Boolean @default(false)

  minPeakSlots Int?

  minNormalSlots Int?

  payoutTiming PayoutTiming @default(POST_SLOT)

  maxRewardPerDay Float?

  maxRewardPerWeek Float?

  maxUsagePerRider Int?

  priority Int @default(1)

  // Weekly rules

  totalDaysInWeek Int @default(7)

  minOrdersPerDay Int?

  allowPartialDays Boolean @default(true)

  status IncentiveStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  slabs IncentiveSlab[]

  progress RiderIncentiveProgress[]

  payouts  IncentivePayout[]
  isLocked Boolean           @default(false)
  lockedAt DateTime?

  @@index([status])
  @@index([incentiveType])
}

/////////////////////////////////////////////////////

// Incentive Slabs

/////////////////////////////////////////////////////

model IncentiveSlab {
  id String @id @default(uuid())

  incentiveId String

  slotType SlotType

  minOrders Int

  maxOrders Int

  rewardAmount Float

  incentive Incentive @relation(fields: [incentiveId], references: [id])

  @@index([incentiveId])
}

/////////////////////////////////////////////////////

// Incentive Payout

/////////////////////////////////////////////////////

model IncentivePayout {
  id String @id @default(uuid())

  incentiveId String

  riderId String

  progressId String?

  earnedAmount Float

  payoutStatus PayoutStatus @default(PENDING)

  payoutReferenceId String?

  walletTransactionId String?

  payoutDate DateTime?

  creditedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  incentive Incentive @relation(fields: [incentiveId], references: [id])

  rider Rider @relation(fields: [riderId], references: [id])

  progress RiderIncentiveProgress? @relation(fields: [progressId], references: [id])

  @@index([riderId])
  @@index([payoutStatus])
}

/////////////////////////////////////////////////////

// ENUMS

/////////////////////////////////////////////////////

enum IncentiveType {
  PEAK_SLOT

  DAILY_TARGET

  WEEKLY_TARGET
}

enum IncentiveProgressType {
  PEAK

  DAILY_TARGET

  WEEKLY_TARGET
}

enum IncentiveStatus {
  ACTIVE

  INACTIVE
}

enum IncentiveProgressStatus {
  IN_PROGRESS

  ACHIEVED

  PAID
}

enum SlotType {
  PEAK

  NORMAL
}

enum PayoutTiming {
  INSTANT

  POST_SLOT

  DAILY

  WEEKLY
}

enum PayoutStatus {
  PENDING

  CREDITED
}

model AssetInventory {
  id            String   @id @default(uuid())
  assetMasterId String
  addedQuantity Int
  availableQty  Int
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assetMaster AssetMaster @relation(fields: [assetMasterId], references: [id], onDelete: Cascade)

  @@index([assetMasterId])
}

enum DeliveryMode {
  HOME_DELIVERY
  PICKUP
}

model City {
  id String @id @default(cuid())

  name String @unique

  state String

  isActive Boolean @default(true)

  pincodes Pincode[]

  createdAt DateTime @default(now())

  updatedAt    DateTime      @updatedAt
  weeklySlots  WeeklySlot[]
  slotBookings SlotBooking[]
}

model Pincode {
  id String @id @default(cuid())

  code String

  name String

  isActive Boolean @default(true)

  cityId String

  city City @relation(fields: [cityId], references: [id])

  areas Area[]

  createdAt DateTime @default(now())

  updatedAt    DateTime      @updatedAt
  weeklySlots  WeeklySlot[]
  slotBookings SlotBooking[]

  @@unique([code, cityId]) // same pincode can exist in different cities 
}

model Area {
  id String @id @default(cuid())

  name String

  isActive Boolean @default(true)

  pincodeId String

  pincode Pincode @relation(fields: [pincodeId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([name, pincodeId])
}

model RiderLocation {
  id String @id @default(uuid())

  riderId String @unique

  streetAddress String?

  area String?

  city String?

  state String?

  pincode String?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model RiderPerformance {
  id String @id @default(uuid())

  riderId String

  periodStart DateTime

  periodEnd DateTime

  averageRating Float @default(0)

  totalRatings Int @default(0)

  totalOrdersAssigned Int @default(0)

  totalOrdersAccepted Int @default(0)

  totalOrdersRejected Int   @default(0)
  acceptanceRate      Float @default(0)
  rejectionPenalty    Float @default(0)

  performanceScore Float @default(0.7)

  calculatedAt DateTime @default(now())

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, periodStart, periodEnd])
  @@index([riderId])
}

model RiderGpsHistory {
  id String @id @default(uuid())

  riderId String

  latitude Float

  longitude Float

  recordedAt DateTime @default(now())

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId, recordedAt])
}

model RiderRating {
  id String @id @default(uuid())

  orderId String @unique
  riderId String

  rating Float
  review String?

  createdAt DateTime @default(now())

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([createdAt])
}
